{
  "entities": {
    "Product": {
      "title": "Product",
      "description": "An e-commerce product",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "price": { "type": "number" },
        "description": { "type": "string" },
        "image": { "type": "string", "description": "Base64 encoded image" },
        "category": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["name", "price", "image"]
    },
    "Order": {
      "title": "Order",
      "description": "A customer order",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "customerName": { "type": "string" },
        "customerPhone": { "type": "string" },
        "items": { "type": "array", "items": { "type": "object" } },
        "total": { "type": "number" },
        "screenshot": { "type": "string", "description": "Base64 encoded screenshot" },
        "status": { "type": "string", "enum": ["pending", "packed", "shipped", "out-for-delivery", "delivered"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["customerName", "customerPhone", "items", "total", "screenshot"]
    },
    "User": {
      "title": "User",
      "description": "A registered user",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string" },
        "role": { "type": "string", "enum": ["user", "admin"] }
      },
      "required": ["uid", "email", "role"]
    },
    "Review": {
      "title": "Review",
      "description": "A customer review for a product",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "productId": { "type": "string" },
        "userId": { "type": "string" },
        "userName": { "type": "string" },
        "rating": { "type": "number" },
        "comment": { "type": "string" },
        "image": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["productId", "userId", "userName", "rating", "comment"]
    }
  },
  "firestore": {
    "products": {
      "schema": "Product",
      "description": "Collection of products"
    },
    "orders": {
      "schema": "Order",
      "description": "Collection of customer orders"
    },
    "users": {
      "schema": "User",
      "description": "Collection of user profiles"
    },
    "reviews": {
      "schema": "Review",
      "description": "Collection of product reviews"
    }
  }
}
